[Unit]
Description=Low-latency AV-over-IP receiver
After=network-online.target sound.target
Wants=network-online.target

[Service]
Type=simple
ExecStart=/usr/local/bin/rx --config /etc/avoverip/rx.toml
Restart=on-failure
RestartSec=1
Environment=RUST_LOG=info
WorkingDirectory=/opt/avoverip
NoNewPrivileges=true

[Install]
WantedBy=multi-user.target
